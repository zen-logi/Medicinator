# 公開ホスト名設定
MEDICINATOR_API_HOST=api.example.com
MEDICINATOR_FRONTEND_ORIGIN=https://medicinator.example.pages.dev

# ASP.NET Core 実行設定
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# Firebase Auth
# サービスアカウント秘密情報ではなく Firebase プロジェクト ID を指定する
FIREBASE_PROJECT_ID=your-firebase-project-id

# SQLite DB
# Docker Composeでは /data を永続volumeとしてマウントする
MEDICINATOR_DB_CONNECTION=Data Source=/data/medicinator.db
MEDICINATOR_APPLY_MIGRATIONS_ON_STARTUP=true

# 任意のリバースプロキシ連携
CLOUDFLARE_PROXY_ENABLED=true
