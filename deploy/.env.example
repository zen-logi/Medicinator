# Cloudflare Workers runtime variables
FIREBASE_PROJECT_ID=your-firebase-project-id
FRONTEND_ORIGIN=https://app.example.com
AUTH_DEV_BYPASS=false

# Cloudflare Pages frontend variables
VITE_API_BASE_URL=https://api.example.com
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# GitHub Actions / Cloudflare Workers deployment variables
CLOUDFLARE_WORKER_DIRECTORY=workers/medicinator-api
D1_DATABASE_NAME=medicinator
D1_DATABASE_ID=replace-with-your-d1-database-id
CLOUDFLARE_WORKER_ENV=
